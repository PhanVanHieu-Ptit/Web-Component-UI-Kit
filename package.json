{
  "name": "@ui-kit/web-components",
  "version": "0.1.0",
  "description": "A Web Component UI Kit built with Lit 3.x",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "wtr --coverage",
    "test:watch": "wtr --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md,mjs,cjs}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{json,md,mjs,cjs}\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "web-components",
    "lit",
    "ui-kit",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.50.0",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/web-components": "^8.6.18",
    "@storybook/web-components-vite": "^8.6.18",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@web/dev-server-esbuild": "^1.0.2",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "storybook": "^8.6.18",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.3.0"
  }
}
